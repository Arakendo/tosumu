<Window x:Class="Tosumu.WpfHarness.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tosumu Harness"
        Width="1380"
        Height="900"
        MinWidth="1100"
        MinHeight="760"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Bahnschrift">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="20"
                Margin="0,0,0,18"
                Background="{StaticResource AccentBrush}"
                CornerRadius="16">
            <DockPanel>
                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="Tosumu Harness" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="14"
                               Foreground="#F2F6F7"
                               Text="Inspection shell for entering a database, checking integrity, and navigating page structure through the packaged CLI contract." />

                    <Border Margin="0,16,0,0"
                            Padding="14,12"
                            Background="{StaticResource AccentDeepBrush}"
                            CornerRadius="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock FontSize="12"
                                           Foreground="#C8DDE4"
                                           Text="Current database" />
                                <TextBlock Margin="0,3,0,0"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Text="{Binding CurrentDatabaseTitleText}" />
                                <TextBlock Margin="0,5,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="#E6F0F3"
                                           Text="{Binding CurrentDatabaseDetailText}" />
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Margin="16,0,0,0"
                                    Padding="12,6"
                                    VerticalAlignment="Top"
                                    Background="{Binding VerificationBadgeBrush}"
                                    CornerRadius="999">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}"
                                           Text="{Binding VerificationBadgeText}" />
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Padding="18"
                Margin="0,0,0,18"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.ColumnSpan="6"
                           Margin="0,0,0,10"
                           FontSize="13"
                           Foreground="{StaticResource MutedTextBrush}"
                           Text="Database path" />

                <TextBox x:Name="DatabasePathTextBox"
                         Grid.Row="1"
                         Grid.Column="0"
                         MinWidth="480"
                         Padding="12,10"
                         VerticalContentAlignment="Center"
                         Background="White"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"
                         Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}" />

                <Button x:Name="BrowseButton"
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        Padding="16,10"
                        Click="BrowseButton_OnClick"
                        Content="Browse" />

                <Button x:Name="LoadHeaderButton"
                        Grid.Row="1"
                        Grid.Column="2"
                        Margin="12,0,0,0"
                        Padding="16,10"
                        Click="LoadHeaderButton_OnClick"
                    Content="Reload Header" />

                <Button x:Name="VerifyButton"
                        Grid.Row="1"
                        Grid.Column="3"
                        Margin="12,0,0,0"
                        Padding="16,10"
                    Background="{StaticResource AccentBrush}"
                    Foreground="White"
                    FontWeight="SemiBold"
                        Click="VerifyButton_OnClick"
                        Content="Verify" />

                <Button x:Name="InspectProtectorsButton"
                    Grid.Row="1"
                    Grid.Column="4"
                    Margin="12,0,0,0"
                    Padding="16,10"
                    Click="InspectProtectorsButton_OnClick"
                    Content="Protectors" />

                <Button x:Name="RefreshAllButton"
                    Grid.Row="1"
                    Grid.Column="5"
                    Margin="12,0,0,0"
                    Padding="16,10"
                    Click="RefreshAllButton_OnClick"
                    Content="Refresh All" />

                <Grid Grid.Row="2"
                      Grid.ColumnSpan="6"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Unlock when needed" />

                    <ComboBox x:Name="UnlockModeComboBox"
                              Grid.Column="1"
                              Width="170"
                              Margin="0,0,12,0"
                              VerticalContentAlignment="Center"
                              SelectionChanged="UnlockModeComboBox_OnSelectionChanged">
                           <ComboBoxItem Tag="Auto" Content="Auto when needed" />
                        <ComboBoxItem Tag="Passphrase" Content="Passphrase" />
                        <ComboBoxItem Tag="RecoveryKey" Content="Recovery key" />
                        <ComboBoxItem Tag="Keyfile" Content="Keyfile" />
                    </ComboBox>

                    <TextBlock x:Name="SecretLabelTextBlock"
                               Grid.Column="2"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Passphrase"
                               Visibility="Collapsed" />

                    <PasswordBox x:Name="SecretPasswordBox"
                                 Grid.Column="3"
                                 Padding="12,10"
                                 VerticalContentAlignment="Center"
                                 Background="White"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 BorderThickness="1"
                                 Visibility="Collapsed" />

                    <TextBox x:Name="KeyfilePathTextBox"
                             Grid.Column="3"
                             Padding="12,10"
                             VerticalContentAlignment="Center"
                             Background="White"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Visibility="Collapsed" />

                    <Button x:Name="BrowseKeyfileButton"
                            Grid.Column="4"
                            Margin="12,0,0,0"
                            Padding="16,10"
                            Click="BrowseKeyfileButton_OnClick"
                            Content="Browse Keyfile"
                            Visibility="Collapsed" />
                </Grid>

                                <TextBlock Grid.Row="3"
                                                     Grid.ColumnSpan="6"
                                                     Margin="0,8,0,0"
                                                     TextWrapping="Wrap"
                                                     Foreground="{StaticResource MutedTextBrush}"
                                                     Text="{Binding UnlockModeHintText}" />

                                <Grid Grid.Row="4"
                                            Grid.ColumnSpan="6"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Inspect page" />

                    <TextBox x:Name="PageNumberTextBox"
                             Grid.Column="1"
                             Padding="12,10"
                             VerticalContentAlignment="Center"
                             Background="White"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             Text="{Binding PageNumberText, UpdateSourceTrigger=PropertyChanged}" />

                    <Button x:Name="InspectPageButton"
                            Grid.Column="2"
                            Margin="12,0,0,0"
                            Padding="16,10"
                            Click="InspectPageButton_OnClick"
                            Content="Inspect Page" />

                                        <Button x:Name="InspectRootPageButton"
                            Grid.Column="3"
                            Margin="12,0,0,0"
                            Padding="16,10"
                            Click="InspectRootPageButton_OnClick"
                            Content="Inspect Root Page" />

                                        <TextBlock Grid.Column="4"
                               Margin="16,0,0,0"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedTextBrush}"
                                                             Text="Select a page or jump straight to root. Root page inspection reloads the header first so the page number stays aligned with the current file." />
                </Grid>

                                <Grid Grid.Row="5"
                                            Grid.ColumnSpan="6"
                      Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Recent databases" />

                    <ComboBox x:Name="RecentDatabasesComboBox"
                              Grid.Column="1"
                              MinWidth="480"
                              Padding="8,6"
                              ItemsSource="{Binding RecentDatabasePaths}"
                              SelectionChanged="RecentDatabasesComboBox_OnSelectionChanged" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Padding="16"
                Margin="0,0,0,18"
                Background="{StaticResource AccentSoftBrush}"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="Status" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="{Binding StatusText}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               Text="CLI resolution" />
                    <TextBlock Margin="0,4,0,0"
                               TextWrapping="Wrap"
                               Text="{Binding ExecutableStateText}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.9*" />
                <RowDefinition Height="0.95*" />
                <RowDefinition Height="1.1*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,12,12"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,12"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="Header" />
                    <ListView ItemsSource="{Binding HeaderRows}"
                              BorderThickness="0"
                              Background="Transparent">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="190" Header="Field" DisplayMemberBinding="{Binding Label}" />
                                <GridViewColumn Width="300" Header="Value" DisplayMemberBinding="{Binding Value}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="1"
                    Margin="12,0,0,12"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="Verify Summary" />
                    <TextBlock Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               FontSize="15"
                               Text="{Binding VerifySummaryText}" />
                    <TextBlock Margin="0,18,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="Protectors" />
                    <ListView ItemsSource="{Binding ProtectorSlots}"
                              Margin="0,10,0,0"
                              BorderThickness="0"
                              Background="Transparent"
                              Height="180">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="80" Header="Slot" DisplayMemberBinding="{Binding Slot}" />
                                <GridViewColumn Width="180" Header="Kind" DisplayMemberBinding="{Binding Kind}" />
                                <GridViewColumn Width="100" Header="Kind Byte" DisplayMemberBinding="{Binding KindByte}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,12,12,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,12"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="Issues" />
                    <ListView ItemsSource="{Binding VerifyIssues}"
                              x:Name="VerifyIssuesListView"
                              BorderThickness="0"
                              Background="Transparent"
                              SelectionChanged="VerifyIssuesListView_OnSelectionChanged"
                              MouseDoubleClick="VerifyIssuesListView_OnMouseDoubleClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasIssue}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="80" Header="Page" DisplayMemberBinding="{Binding Pgno}" />
                                <GridViewColumn Width="430" Header="Description" DisplayMemberBinding="{Binding Description}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Margin="12,12,0,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="0,0,0,12"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="Page Results" />
                    <ListView ItemsSource="{Binding PageResults}"
                              x:Name="PageResultsListView"
                              BorderThickness="0"
                              Background="Transparent"
                              SelectionChanged="PageResultsListView_OnSelectionChanged"
                              MouseDoubleClick="PageResultsListView_OnMouseDoubleClick">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasIssue}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource DangerSoftBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="80" Header="Page" DisplayMemberBinding="{Binding Pgno}" />
                                <GridViewColumn Width="90" Header="Auth" DisplayMemberBinding="{Binding AuthOkLabel}" />
                                <GridViewColumn Width="120" Header="Version" DisplayMemberBinding="{Binding PageVersionLabel}" />
                                <GridViewColumn Width="250" Header="Issue" DisplayMemberBinding="{Binding Issue}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </DockPanel>
            </Border>

            <Border Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Margin="0,12,0,0"
                    Padding="16"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0"
                          Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Page Detail" />

                        <CheckBox x:Name="ShowHexColumnsCheckBox"
                                  Grid.Column="1"
                                  VerticalAlignment="Center"
                                  Checked="ShowHexColumnsCheckBox_OnChanged"
                                  Unchecked="ShowHexColumnsCheckBox_OnChanged"
                                  Content="Show hex columns" />
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"
                               FontSize="15"
                               Text="{Binding PageSummaryText}" />

                    <Border Grid.Row="2"
                            Margin="0,0,0,12"
                            Padding="12"
                            Background="{StaticResource AccentSoftBrush}"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock FontSize="13"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="Selected record" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedRecordHeadlineText}" />
                            <TextBlock Margin="0,4,0,0"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedRecordDetailText}" />
                        </StackPanel>
                    </Border>

                    <ListView x:Name="PageRecordsListView"
                              Grid.Row="3"
                              ItemsSource="{Binding PageRecords}"
                              BorderThickness="0"
                              Background="Transparent"
                              SelectionChanged="PageRecordsListView_OnSelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="6,4" />
                                <Setter Property="Margin" Value="0,0,0,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaceholder}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource InfoSoftBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="100" Header="Kind" DisplayMemberBinding="{Binding Kind}" />
                                <GridViewColumn Width="80" Header="Slot" DisplayMemberBinding="{Binding Slot}" />
                                <GridViewColumn Width="110" Header="Record Type" DisplayMemberBinding="{Binding RecordType}" />
                                <GridViewColumn Width="180" Header="Key Preview" DisplayMemberBinding="{Binding KeyPreview}" />
                                <GridViewColumn x:Name="KeyHexColumn" Width="320" Header="Key Hex" DisplayMemberBinding="{Binding KeyHex}" />
                                <GridViewColumn Width="220" Header="Value Preview" DisplayMemberBinding="{Binding ValuePreview}" />
                                <GridViewColumn x:Name="ValueHexColumn" Width="420" Header="Value Hex" DisplayMemberBinding="{Binding ValueHex}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
